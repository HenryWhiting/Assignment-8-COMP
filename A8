import math

from PyQt5.QtGui import *
from PyQt5.QtWidgets import *
from PyQt5.QtCore import *


def load_sprite(sprite_folder_name, number_of_frames):
    frames = []
    padding = math.ceil(math.log(number_of_frames - 1, 10))
    for frame in range(number_of_frames):
        folder_and_file_name = (
            sprite_folder_name
            + "/sprite_"
            + str(frame).rjust(padding, '0')
            + ".png"
        )
        frames.append(QPixmap(folder_and_file_name))
    return frames


class SpritePreview(QMainWindow):

    def __init__(self):
        super().__init__()
        self.setWindowTitle("Sprite Animation Preview")

        self.num_frames = 21
        self.frames = load_sprite('spriteImages', self.num_frames)

        self.timer = QTimer()
        self.timer.timeout.connect(self.next_frame)

        self.is_animating = False
        self.current_frame = 0

        self.setupUI()

    # fps + timer speed update
    def update_fps(self, value):
        self.fps_value_label.setText(str(value))

        interval = int(1000 / value)

        if self.is_animating:
            self.timer.start(interval)

    def setupUI(self):
        frame = QFrame()
        layout = QVBoxLayout()

        layout.setSpacing(15)
        layout.setContentsMargins(20, 20, 20, 20)

        self.setStyleSheet("""
            QWidget {
                background-color: #f4f6f8;
                font-family: Arial;
            }
        """)

        # sprite
        self.sprite_label = QLabel()
        self.sprite_label.setAlignment(Qt.AlignCenter)
        self.sprite_label.setFixedSize(300, 300)

        self.sprite_label.setStyleSheet("""
            QLabel {
                background-color: white;
                border: 2px solid #cccccc;
                border-radius: 10px;
            }
        """)

        if self.frames:
            self.sprite_label.setPixmap(self.frames[self.current_frame])

        # timer
        self.timer_label = QLabel("Frame: 1 / " + str(self.num_frames))
        self.timer_label.setAlignment(Qt.AlignCenter)

        # fps
        controls_layout = QHBoxLayout()

        fps_text_label = QLabel("Frames per second")

        self.fps_value_label = QLabel("1")

        self.fps_slider = QSlider(Qt.Horizontal)
        self.fps_slider.setMinimum(1)
        self.fps_slider.setMaximum(100)
        self.fps_slider.setValue(1)

        self.fps_slider.setTickPosition(QSlider.TicksBelow)
        self.fps_slider.setTickInterval(10)

        self.fps_slider.valueChanged.connect(self.update_fps)

        controls_layout.addWidget(fps_text_label)
        controls_layout.addWidget(self.fps_slider)
        controls_layout.addWidget(self.fps_value_label)

        # buttons
        button_layout = QVBoxLayout()

        # start and stop 
        self.start_button = QPushButton("Start")
        self.start_button.clicked.connect(self.toggle_animation)

        self.start_button.setStyleSheet("""
            QPushButton {
                background-color: #2ecc71;
                color: white;
                font-size: 16px;
                border-radius: 8px;
                padding: 10px;
            }
        """)

        button_layout.addWidget(self.start_button)

        # Pause + Exit 
        bottom_row = QHBoxLayout()

        self.pause_button = QPushButton("Pause")
        self.pause_button.clicked.connect(self.pause_animation)

        self.exit_button = QPushButton("Exit")
        self.exit_button.clicked.connect(self.exit_application)

        self.pause_button.setStyleSheet("""
            QPushButton {
                background-color: #f39c12;
                color: white;
                font-size: 14px;
                border-radius: 8px;
                padding: 8px;
            }
        """)

        self.exit_button.setStyleSheet("""
            QPushButton {
                background-color: #34495e;
                color: white;
                font-size: 14px;
                border-radius: 8px;
                padding: 8px;
            }
        """)

        bottom_row.addWidget(self.pause_button)
        bottom_row.addWidget(self.exit_button)

        button_layout.addLayout(bottom_row)

        
        layout.addWidget(self.sprite_label)
        layout.addWidget(self.timer_label)
        layout.addLayout(controls_layout)
        layout.addLayout(button_layout)

        frame.setLayout(layout)
        self.setCentralWidget(frame)

        # Menu
        menubar = self.menuBar()
        menu = menubar.addMenu("Menu")

        pause_action = QAction("Pause", self)
        pause_action.triggered.connect(self.pause_animation)
        menu.addAction(pause_action)

        exit_action = QAction("Exit", self)
        exit_action.triggered.connect(self.exit_application)
        menu.addAction(exit_action)

    
    def toggle_animation(self):
        if not self.is_animating:
            fps = self.fps_slider.value()
            self.timer.start(int(1000 / fps))

            self.start_button.setText("Stop")
            self.is_animating = True

        else:
            self.timer.stop()

            self.start_button.setText("Start")
            self.is_animating = False

    # Frame updater
    def next_frame(self):
        self.current_frame = (self.current_frame + 1) % len(self.frames)

        self.sprite_label.setPixmap(self.frames[self.current_frame])

        # label update
        self.timer_label.setText(
            f"Frame: {self.current_frame + 1} / {len(self.frames)}"
        )

    # Pause
    def pause_animation(self):
        if self.is_animating:
            self.timer.stop()
            self.start_button.setText("Start")
            self.is_animating = False

    def exit_application(self):
        QApplication.quit()


def main():
    app = QApplication([])
    window = SpritePreview()
    window.show()
    app.exec()


if __name__ == "__main__":
    main()
